# Auth: the agent uses the Claude Code CLI's own login (subscription), not an API key.
# The agent host must have the CLI installed and logged in (`claude` / `claude setup-token`).
# Do NOT set ANTHROPIC_API_KEY — if present it overrides CLI auth.

# Web server (run queue API). Local dev: http://localhost:8000
# Prod: the agent on `home` talks to the web server on rpi6
WEB_URL=http://localhost:8000

# Must match the web server's AGENT_TOKEN
AGENT_TOKEN=change-me-agent-token

# Per-run sandbox folders live here
SANDBOX_ROOT=sandboxes

# Remote puppeteer MCP (stays on the LAN)
PUPPETEER_MCP_URL=http://localhost:8765/mcp

# Sandbox file API port (served in-process, exposed via Apache at /workflow-agent)
AGENT_HTTP_PORT=9006

# Optional tuning
POLL_SECONDS=3
MAX_TURNS=40
# AGENT_MODEL=claude-sonnet-4-6
