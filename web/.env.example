# Web server
HOST=0.0.0.0
PORT=8000
# Public path prefix when hosted under a sub-path (prod: /workflow on rpi6). Empty for local dev.
# Used by run.sh as uvicorn --root-path.
ROOT_PATH=
SECRET_KEY=change-me-in-production
DB_PATH=workflow.db
UPLOADS_DIR=uploads

# Shared service token the agent server uses to claim/report runs
AGENT_TOKEN=change-me-agent-token

# Agent host's sandbox file API (for browsing a run's files). Prod: https://home.memention.net/workflow-agent
# Unset -> the "Browse files" page shows a not-configured notice.
AGENT_FILES_URL=

# Public URL used in email links (Apache proxies /workflow on rpi6)
FRONTEND_URL=https://rpi6.memention.net/workflow

# Mailjet (unset -> verify/reset links are printed to run.log instead of emailed; fine for dev).
# FROM_EMAIL must be a Mailjet-verified sender for your account.
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
MAILJET_FROM_EMAIL=noreply@example.com
MAILJET_FROM_NAME=Workflow Builder
